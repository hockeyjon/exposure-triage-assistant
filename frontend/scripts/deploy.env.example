# Don't use ~ in REMOTE_PATH — deploy.sh sources this file, and bash expands
# ~ locally at that point (to your own machine's home dir), not on the
# remote server. Use a relative path (resolved from your SSH login
# directory) or a full absolute remote path instead.
#
# This deploys as its own standalone web app under a subdirectory, not the
# domain root (matches next.config.ts's basePath: "/vulnerabilityscanner").
REMOTE_USER=your_cpanel_username
REMOTE_HOST=your.server.ip.or.hostname
REMOTE_PATH=./www/gunbarrelstudio.com/vulnerabilityscanner
SSH_KEY=~/.ssh/your_key
