# Choose the LLM backing the narration/critique nodes: "anthropic" or "openai"
LLM_PROVIDER=anthropic

# Anthropic (used if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# OpenAI (used if LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# CORS: origin the Next.js frontend is served from. In production this
# barely matters in practice — frontend/public/.htaccess proxies /api/* to
# this backend under the *same* origin (https://www.gunbarrelstudio.com),
# so the browser never treats it as cross-origin. Set it anyway, as
# defense-in-depth in case the backend's port is ever reachable directly:
# FRONTEND_ORIGIN=https://www.gunbarrelstudio.com
FRONTEND_ORIGIN=http://localhost:3000

# Max number of top-ranked findings sent to the LLM for narration/critique
MAX_NARRATED_FINDINGS=12

# Hard cap on LLM calls per day (draft_rationale + critique + findings chat +
# its auto-titling, combined), as a backstop against a runaway loop or
# unexpected traffic running up an API bill. Past the cap, those features
# degrade the same way they already do without an LLM key — a clear inline
# message, not a hard failure. Resets at UTC midnight. 0 disables the limit.
DAILY_LLM_CALL_LIMIT=20

# AWS SES — sends the "daily limit increase request" email offered once
# DAILY_LLM_CALL_LIMIT is hit. SES_SENDER_EMAIL must be a verified sending
# identity in the SES account these credentials belong to; SES starts new
# accounts in sandbox mode, where the recipient address (LIMIT_REQUEST_
# NOTIFY_EMAIL) needs to be verified too until production access is granted.
AWS_REGION=us-east-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_SENDER_EMAIL=jon@gunbarrelstudio.com
LIMIT_REQUEST_NOTIFY_EMAIL=jon@gunbarrelstudio.com

# How many limit-increase-request emails /contact/limit-increase will send
# per day — low on purpose, this exists to catch a genuine, occasional
# request, not to double as a general-purpose contact form.
LIMIT_INCREASE_REQUEST_DAILY_CAP=10

# Off by default. Set true to merge a handful of intentionally outdated,
# real-CVE demo packages (tagged source="demo") into the inventory, so the
# ranking UI has something to show without this project actually having a
# vulnerable dependency. See backend/app/inventory.py DEMO_PACKAGES.
INCLUDE_DEMO_PACKAGES=false

# Leave unset for local dev — inventory.py falls back to the sibling
# ../frontend directory, which has the real package.json/package-lock.json.
# In production, the frontend is deployed to a separate, unrelated
# directory that only contains its static build output (no package.json —
# it's never part of what a static export ships). deploy.sh bundles
# a copy of the frontend's manifest into ./frontend-manifest alongside this
# backend; point this at it in production:
# FRONTEND_DIR=./frontend-manifest
FRONTEND_DIR=
